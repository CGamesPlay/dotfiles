#!/bin/bash
# @describe Launch Neovide connected to nvim over SSH
#
# This script allows you to launch Neovide and connect to a remote host via
# SSH, with support for changing to a specific directory and opening files.
#
# @option --ssh-args  SSH arguments to pass (e.g., "-l ubuntu")
# @option --chdir     Directory to change to on the remote host
# @arg host!          Hostname or IP address to SSH into
# @arg files*         Files to open in nvim

set -ue

# Quotes each argument so that it will be interpreted as a single literal
# argument in POSIX shells and fish.
shellquote() {
	while [ $# -gt 0 ]; do
		arg="$1"
		# Can't use printf %q because it produces strings that are not
		# interpretable by dash. We can't use the POSIX-compliant way to
		# escape with single quotes either because fish interprets them
		# differently (which breaks double-quoted strings). So, we replace
		# quotes with '\'' as normal but additionally replace backslash
		# with '\\'.
		# We will use `a` as a temporary escape character. `aa` will
		# produce `a`, `a'` will produce `'\''` and `a\` will produce
		# `'\\'`.
		# 1. Quote special characters.
		arg=${arg//a/aa}
		arg=${arg//\'/a\'}
		arg=${arg//\\/a\\}
		# 2. Unquote.
		arg=${arg//a\\/\'\\\\\'}
		arg=${arg//a\'/\'\\\'\'}
		arg=${arg//aa/a}
		arg=\'$arg\'
		echo -n "$arg "
		shift
	done
}

main() {
	# Shell script to run on the remote end, by remote default shell.
	remote_script='nvim "$@"'
	if [[ ${argc_chdir+1} ]]; then
		remote_script=$(printf 'cd %q && exec direnv exec . %s' "$argc_chdir" "$remote_script")
	fi
	ssh_args=("${argc_host:?}" ${argc_ssh_args+"${args_ssh_args[@]}"} -- sh -c "$(shellquote "$remote_script")" neovide-trampoline --listen neovide)
	cmd=(
		neovide-remote --no-tabs
		--neovim-bin=ssh
		${argc_files+$(printf -- '--file=%q ' "${argc_files[@]}")} \
		-- "${ssh_args[@]}"
	)
	"${cmd[@]}"
}

if ! command -v argc >/dev/null; then
	echo "This command requires argc. Install from https://github.com/sigoden/argc" >&2
	exit 100
fi
eval "$(argc --argc-eval "$0" "$@")"
