### Visitors!
### Please borrow freely from this config, but make sure to change
### the [user] section to your info

[user]
  name = Ryan Patterson
  email = cgamesplay@cgamesplay.com

[core]
  excludesfile = ~/.gitignore
  whitespace = trailing-space,space-before-tab
  pager = less
	editor = vim
	mergeoptions = --no-edit

### colors are meant for a dark terminal
[color]
  ui = auto
  diff = auto
  status = auto
  branch = auto
  interactive = auto
[color "branch"]
  current = white blue bold
  local  = blue
  remote = green
[color "diff"]
  plain = reset
  meta = yellow bold
  frag = magenta bold
  old = red
  new = green
  whitespace = red blink
[color "status"]
  added = yellow
  changed = green
  untracked = cyan

[alias]
  start = checkout @{u} -B
  br = branch -vv
  bg = bisect good
  bb = bisect bad
  co = checkout
  amend = commit --amend
  ci = commit
  st = status
  cp = cherry-pick
  graph = log --oneline --graph --decorate
  track = branch --set-upstream-to
  # Safe remove all branches reachable from HEAD.  Good way to GC old branches after dcommit/rebase
  gcbr = !git branch --no-track --no-color --merged | sed 's/[ *]*//' | grep -v master | xargs -n1 git branch -d &> /dev/null || exit 0
  push-pull = !git pull --rebase && git push
  pull-all = "!git fetch --all && git for-each-ref 'refs/heads/*' --format '%(refname:strip=2)' | while read br; do git checkout $br && git rebase @{u} || git rebase --abort; done"

[svn]
  followparent = true
  rmdir = true

[commit]
[log]
  date = relative
[format]
  # This is (almost) the same as medium (the default) but it uses commit dates
  pretty = tformat:"%C(yellow)commit %H%Creset%nCommitter: %cN <%cE>%nDate:      %cd%n%n%w(0,4,4)%s%n%n%b"
[blame]
  date = short
[diff]
  renames = true
  mnemonicprefix = true
[apply]
  whitespace = strip
[merge]
  tool = emerge
[status]
  relativePaths = false
[web]
  browser = lynx
[rebase]
  stat = true
## for perf reasons (sad), don't add the index-dirtiness state to bash PS1
[bash]
  showDirtyState = false
[rerere]
  enabled = 1
[push]
	default = upstream
[branch]
	autosetuprebase = always
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
