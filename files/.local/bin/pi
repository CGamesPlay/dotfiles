#!/usr/bin/env bash
# @describe Wrapper for Pi
#
# The wrapper auto-installs Pi and runs it.
#
# On macOS, it automatically sandboxes the agent using agent-safehouse.
# @version wrapper, use --pi-version for version information
# @flag --continue        Passed to Pi
# @flag --resume          Passed to Pi
# @flag --pi-help         Show help for Pi
# @flag --pi-version      Show version for Pi
# @flag --pi-reinstall    Reinstall Pi even if already installed
# @flag --skip-safehouse  Don't run in agent-safehouse
# @arg args~              Additional arguments, passed verbatim

set -eu

DFM_DIR=$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")/../.." && pwd)
PI_PACKAGE=@mariozechner/pi-coding-agent
PI_ENV_FILE=~/.pi/agent/env

main() {
	set +u
	# shellcheck disable=1091
	. "${NVM_DIR:?NVM_DIR is not set}/nvm.sh"
	nvm use --lts > /dev/null
	set -u

	# Fast path: check by directory existence rather than slow `npm list -g`.
	local npm_global_root
	npm_global_root=$(npm root -g)

	if [[ "${argc_pi_reinstall+1}" ]] || [[ ! -d "$npm_global_root/$PI_PACKAGE" ]]; then
		echo "Pi is not installed. Installing..." >&2
		npm --no-update-notifier install -g "$PI_PACKAGE"
	fi

	# Install dependencies for any pi extensions that have a package.json.
	# Fast path: check for missing deps by directory existence (no npm invocation).
	# Slow path: acquire a lock to serialize concurrent installs, then re-check and install.
	local missing_deps=() pkg_dep pkg_json lock_file=~/.pi/install.lock
	export NODE_PATH="${NODE_PATH:+$NODE_PATH:}$npm_global_root"

	# Serialize dep checks and installs so concurrent pi processes don't race.
	# noclobber + > is atomic (O_EXCL) on local filesystems — no external tool needed.
	until (set -o noclobber; echo $$ > "$lock_file") 2>/dev/null; do sleep 0.2; done
	trap 'rm -f "$lock_file"' EXIT

	while IFS= read -r pkg_json; do
		while IFS= read -r pkg_dep; do
			[[ -z "$pkg_dep" ]] && continue
			# Scoped packages (@scope/name) map to $npm_global_root/@scope/name
			if [[ ! -d "$npm_global_root/$pkg_dep" ]]; then
				missing_deps+=("$pkg_dep")
			fi
		done < <(node -e "
			const p=require('$pkg_json');
			const d=p.dependencies||{};
			Object.keys(d).forEach(k=>console.log(k));
		" 2>/dev/null)
	done < <(find ~/.pi/agent/extensions -name package.json -maxdepth 2)

	if [[ ${#missing_deps[@]} -gt 0 ]]; then
		npm --no-update-notifier --quiet install -g "${missing_deps[@]}" >/dev/null
	fi

	rm -f "$lock_file"
	trap - EXIT

	if [[ ${argc_pi_help+1} ]] || [[ ${args_pi_version+1} ]]; then
		exec pi \
			${argc_pi_help+--help} \
			${argc_pi_version+--version}
	fi

	local args
	args=(pi ${argc_resume+--resume} ${argc_continue+--continue})

	if [[ ! ${argc_skip_safehouse+1} ]] && [[ "$(uname -s)" = "Darwin" ]]; then
		if ! command -v safehouse >/dev/null; then
			echo "Agent Safehouse is not installed. Installing..." >&2
			@get safehouse
		fi
		script="set -a && source '$PI_ENV_FILE' && exec \"\$@\""
		args=(
			safehouse 
			--enable=clipboard
			--add-dirs-ro ~/.local/bin
			--add-dirs-ro ~/.local/bin-after
			--add-dirs-ro "$NVM_DIR"
			--add-dirs-ro "$DFM_DIR"
			--add-dirs-ro ~/.config/nvim
			--add-dirs-ro ~/.local/share/nvim
			--add-dirs ~/.local/state/nvim
			--add-dirs "$XDG_CACHE_HOME"
			--add-dirs ~/.pi
			--env-pass "EDITOR,NVM_DIR,DFM_DIR,NODE_PATH"
			-- sh -c "$script" "pi-wrapper"
			"${args[@]}"
		)
	fi

	if [[ -e "$PI_ENV_FILE" ]]; then
		set -a && source "$PI_ENV_FILE" && set +a
	else
		echo "Warning: $PI_ENV_FILE does not exist." >&2
	fi

	exec "${args[@]}" ${argc_args+"${argc_args[@]}"}
}

eval "$(argc --argc-eval "$0" "$@")"
