#!/usr/bin/env bash
# @describe Wrapper for Pi
#
# The wrapper auto-installs Pi and runs it. On macOS, it automatically
# sandboxes the agent using agent-safehouse. On Linux, runs unsandboxed.
#
# To upgrade, run `npm install` in share/pi directly.
# @version wrapper, use --pi-version for version information
# @flag   --continue         Continue the latest session
# @flag   --no-session       Don't save this session
# @flag   --skip-safehouse   Don't run in agent-safehouse
# @flag   --debug-safehouse  Run a shell in safehouse instead of running pi
# @flag   --pi-help          Show help for Pi
# @flag   --pi-version       Show version for Pi
# @flag   --pi-reinstall     Reinstall/Upgrade Pi even if already installed
# @option --resume <FILE?>   Resume the given session (or picker if not session file given)
# @option --model <MODEL>    Use a specific model
# @option --thinking <LEVEL> Use a specific thinking level
# @option --preset <PRESET>  Use a saved preset for model/thinking level
# @option --safehouse-rw <DIR> Add a writable directory to safehouse
# @option --safehouse-ro <DIR> Add a readable directory to safehouse
# @arg  args~               Additional arguments, passed verbatim

set -eu

DFM_DIR=$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")/../../.." && pwd)
PI_ENV_FILE=~/.pi/agent/env

main() {
	set +u
	# shellcheck disable=1091
	. "${NVM_DIR:?NVM_DIR is not set}/nvm.sh"
	nvm use --lts > /dev/null
	set -u

	if [[ -e "$PI_ENV_FILE" ]]; then
		# shellcheck disable=SC1090
		set -a && source "$PI_ENV_FILE" && set +a
	else
		echo "Warning: $PI_ENV_FILE does not exist." >&2
	fi

	lock_file=~/.pi/install.lock
	until (set -o noclobber; echo $$ > "$lock_file") 2>/dev/null; do sleep 0.2; done
	trap 'rm -f "$lock_file"' EXIT

	PI_BIN="$DFM_DIR/share/pi/node_modules/.bin/pi"

	if [[ "${argc_pi_reinstall+1}" ]] || [[ ! -x "$PI_BIN" ]]; then
		echo "Pi is not installed. Installing..." >&2
		pushd "$DFM_DIR/share/pi" >/dev/null
		rm -rf node_modules/@mariozechner
		npm --no-update-notifier clean-install --ignore-scripts --omit=dev
		"$PI_BIN" install "$DFM_DIR/share/pi"
		popd >/dev/null
		argc_pi_version=1
	fi

	rm -f "$lock_file"
	trap - EXIT

	if [[ ${argc_pi_help+1} ]] || [[ ${argc_pi_version+1} ]]; then
		exec "$PI_BIN" \
			${argc_pi_help+--help} \
			${argc_pi_version+--version}
	fi

	local args
	args=(
		"$PI_BIN"
		${argc_model+--model "$argc_model"}
		${argc_thinking+--thinking "$argc_thinking"}
		${argc_preset+--preset "$argc_preset"}
	)

	if [[ ${argc_no_session+1} ]]; then
		args+=(--no-session)
	elif [[ ${argc_continue+1} ]]; then
		args+=(--continue)
	elif [[ -n ${argc_resume:-} ]]; then
		args+=(--session "$argc_resume")
	elif [[ ${argc_resume+1} ]]; then
		args+=(--resume)
	fi

	if [[ ! ${argc_skip_safehouse+1} ]] && [[ "$(uname -s)" = "Darwin" ]]; then
		if ! command -v safehouse >/dev/null; then
			echo "Agent Safehouse is not installed. Installing..." >&2
			@get safehouse
		fi
		script="set -a && source '$PI_ENV_FILE' && exec direnv exec . \"\$@\""
		safehouse_args=(
			--enable="clipboard,macos-gui,xcode"
			--add-dirs-ro /Library/Preferences/com.apple.dt.Xcode.plist
			--add-dirs-ro ~/.local/bin
			--add-dirs-ro ~/.local/bin-after
			--add-dirs-ro "$NVM_DIR"
			--add-dirs-ro "$DFM_DIR"
			--add-dirs-ro ~/.config/jj
			--add-dirs-ro ~/.config/nvim
			--add-dirs-ro ~/.config/direnv
			--add-dirs-ro ~/.local/share/nvim
			--add-dirs-ro ~/.local/share/direnv
			--add-dirs-ro ~/Applications
			--add-dirs ~/.local/state/nvim
			--add-dirs "$XDG_CACHE_HOME"
			--add-dirs ~/.pi
			--add-dirs ~/.local/share/claude
			--add-dirs ~/.claude
			--add-dirs ~/.claude.json
			--env-pass "EDITOR,NVM_DIR,DFM_DIR"
			${argc_safehouse_rw+"${argc_safehouse_rw[@]/#/--add-dirs=}"}
			${argc_safehouse_ro+"${argc_safehouse_rw[@]/#/--add-dirs-ro=}"}
		)
		if jj_repo_config=$(jj config path --repo 2>/dev/null); then
			safehouse_args+=(--add-dirs "$(dirname "$jj_repo_config")")
		fi
		if jj_workspace_config=$(jj config path --workspace 2>/dev/null); then
			safehouse_args+=(--add-dirs "$(dirname "$jj_workspace_config")")
		fi
		if [[ ${argc_debug_safehouse+1} ]]; then
			args=("$SHELL")
		fi
		args=(safehouse "${safehouse_args[@]}" -- sh -c "$script" "pi-wrapper" "${args[@]}")
	fi

	exec "${args[@]}" ${argc_args+"${argc_args[@]}"}
}

eval "$(argc --argc-eval "$0" "$@")"
