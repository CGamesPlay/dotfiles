#!/usr/bin/env bash
# @describe Useful commands from my dotfiles.

set -eu

dotfiles_root() {
	path=${BASH_SOURCE[0]}
	realpath -m "$path"/../../../../"${1:-}"
}

# @cmd Create a temporary docker container.
# @arg       image=buildpack-deps:noble  Base image to use
docker-sandbox() {
	container_id=$(docker run -d --rm "${argc_image:?}" sleep infinity)
	docker exec -i "$container_id" sh <<-END_SCRIPT
	apt-get update
	apt-get install -y sudo rsync
	cd ~
	git clone https://gitlab.com/CGamesPlay/dotfiles dotfiles
	cd dotfiles
	./bootstrap.sh
	END_SCRIPT
	status=0
	docker exec -it "$container_id" fish || status=$?
	docker rm -f "$container_id"
	exit "$status"
}

# @cmd Set a reminder that notifies after a duration.
# @arg duration!   Duration (e.g., 1h2m3s, 30m, 45s)
# @arg message!    Message to display
reminder() {
	local duration="${argc_duration:?}"
	local message="${argc_message:?}"

	# Parse duration
	local hours=0 minutes=0 seconds=0
	if [[ $duration =~ ([0-9]+)h ]]; then
		hours=${BASH_REMATCH[1]}
	fi
	if [[ $duration =~ ([0-9]+)m ]]; then
		minutes=${BASH_REMATCH[1]}
	fi
	if [[ $duration =~ ([0-9]+)s ]]; then
		seconds=${BASH_REMATCH[1]}
	fi

	# Calculate total seconds
	local total_seconds=$((hours * 3600 + minutes * 60 + seconds))

	if [ "$total_seconds" -eq 0 ]; then
		echo "Error: Invalid duration" >&2
		exit 1
	fi

	# Wait and notify
	printf "Timer set for %d:%02d:%02d\n" "$hours" "$minutes" "$seconds"
	sleep "$total_seconds"
	@iterm notify "$message"
}

# @cmd Helper scripts for managing dotfiles
# @arg args~[?`_choice_dotfiles`]
dotfiles() {
	cd "$(dotfiles_root)"
	argc "$@"
}

_choice_dotfiles() {
    if [[ "$ARGC_COMPGEN" -eq 1 ]]; then
		local args=( "argc" "${argc__positionals[@]}" )
        args[${#args[@]}-1]="$ARGC_LAST_ARG"
		argc --argc-compgen generic "$(dotfiles_root)/Argcfile.sh" "${args[@]}"
    fi
}

# @cmd Clone a git repository to a predictable location
# @arg args~[?`_choice_external_subcmds`]
clone() {
	"$(dotfiles_root scripts/@argc)/${argc__fn:?}" "$@"
}

# @cmd Instantiate templates
# @arg args~[?`_choice_external_subcmds`]
create() {
	"$(dotfiles_root scripts/@argc)/${argc__fn:?}" "$@"
}

# @cmd Scripts for managing the personal knowledge base
# @arg args~[?`_choice_external_subcmds`]
notes() {
	"$(dotfiles_root scripts/@argc)/${argc__fn:?}" "$@"
}

# @cmd System-level assistant
# @arg args~[?`_choice_external_subcmds`]
pi-sys() {
	"$(dotfiles_root scripts/@argc)/${argc__fn:?}" "$@"
}

# @cmd Commands for working with ruby/rails projects
# @arg args~[?`_choice_external_subcmds`]
rails() {
	"$(dotfiles_root scripts/@argc)/${argc__fn:?}" "$@"
}

# @cmd Tools for mirroring YouTube videos
# @arg args~[?`_choice_external_subcmds`]
yt-dlp() {
	"$(dotfiles_root scripts/@argc)/${argc__fn:?}" "$@"
}

_choice_external_subcmds() {
    if [[ "$ARGC_COMPGEN" -eq 1 ]]; then
		local args=( "$(dotfiles_root scripts/@argc)/$argc__cmd_fn" "${argc__positionals[@]}" )
        args[${#args[@]}-1]="$ARGC_LAST_ARG"
		argc --argc-compgen generic "$(dotfiles_root scripts/@argc)/$argc__cmd_fn" "${args[@]}"
    fi
}

eval "$(argc --argc-eval "$0" "$@")"
