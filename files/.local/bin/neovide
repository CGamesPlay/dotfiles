#!/bin/bash
# Launch neovide using the iTerm2 extension script.

set -ue

if [[ "${1:-}" == "--help" ]]; then
	cat <<-EOF >&2
	neovide is a wrapper to integrate Neovide with iTerm2.

	Usage:
	  neovide [FILENAME]
	EOF
	exit 0
fi

rundir="${XDG_RUNTIME_DIR:-/tmp/nvim.${USER:?}}"
# shellcheck disable=SC2174
mkdir -pm 0700 "$rundir"
socket="${rundir}/${PWD//\//-}"

if [ -S "$socket" ] && fuser "$socket" >/dev/null 2>&1; then
	echo "Nvim server socket exists, sending remote command"
	exec nvim --server "$socket" --remote "$@"

elif [ -d /Applications/Neovide.app ]; then
	# Running locally, run with a trampoline to support direnv
	if [[ "${NEOVIDE_LAUNCHER:+1}" ]]; then
		args=()
		for arg in "$@"; do
			case "$arg" in
				--prefix=*)
					prefix=${arg#--prefix=}
					;;
				*)
					args+=("$arg")
					;;
			esac
		done
		unset NEOVIDE_LAUNCHER
		exec sh -c "$prefix $(printf '%q ' "${args[@]}")"
	else
		prefix="$(printf "cd %q && exec direnv exec . nvim --listen %q" "$PWD" "$socket")"
		NEOVIDE_LAUNCHER=1 exec open -na Neovide --args --wsl --neovim-bin="$0" -- --prefix="$prefix" "$@"
	fi

else
	# Running in a remote environment, open using iTerm2 custom escape sequence.
	echo "Launching Neovide through iTerm custom escape"
	value="id=neovide:"
	if [[ "${1:+1}" ]]; then
		value="${value}filename=$1"
	fi

	printf "\033]1337;RemoteHost=%s@%s\a\033]1337;CurrentDir=%s\a" "$USER" "$(hostname -f)" "$PWD"
	printf "\033]1337;Custom=%s\a" "$value"
fi
