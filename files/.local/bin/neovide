#!/usr/bin/env bash
# @describe Edit files in Neovide
#
# This command can:
# - Start a new Neovide instance attached to a new nvim session
# - Open a file in an existing nvim session
# - Attach Neovide to an existing nvim session
#
# Works locally and from a remote via iTerm2 extension.
# @option --socket <SOCKET?>     Path to an existing nvim session
# @arg    files~                 Passed to nvim

set -ue

main() {
	# Select the nvim session.
	if [[ ! "${argc_socket:+1}" ]]; then
		argc_socket=$(pick_socket ${argc_socket+always}) || exit 0
	fi

	# If we have a socket, communicate with nvim directly.
	if [[ ${argc_socket:+1} ]]; then
		echo "Opening in existing Neovide session" >&2
		if [[ ${argc_files+1} ]]; then
			cmd="<C-\\><C-N>:drop $(printf '%q ' "$PWD/${argc_files[@]}") | NeovideFocus<CR>"
		else
			cmd="<C-\\><C-N>:drop $(printf '%q ' "$PWD") | NeovideFocus<CR>"
		fi
		exec nvim --headless --server "$argc_socket" --remote-send "$cmd"
	fi

	# Otherwise we need to create a new session by starting Neovide
	if command -v neovide-remote >/dev/null; then
		launch_local
	else
		launch_remote
	fi
}

pick_socket() {
	local rundir="${XDG_RUNTIME_DIR:-/tmp/nvim.${USER:?}}"
	local -a sockets=()
	local -a entries=()
	local sock cwd

	while IFS= read -r -d '' sock; do
		sockets+=("$sock")
	done < <(find "$rundir" -type s -name 'neovide.*' -print0 2>/dev/null)

	# Build label → socket map and check for pwd matches.
	local -a pwd_matches=()
	for sock in ${sockets+"${sockets[@]}"}; do
		cwd=$(nvim --headless --server "$sock" --remote-expr "getcwd()" 2>/dev/null) || continue
		if [[ "$cwd" == "$PWD" ]]; then
			pwd_matches+=("$sock")
		fi
		entries+=("Session $(basename "$sock") in $cwd"$'\t'"$sock")
	done

	if [[ "${1:-}" != "always" ]]; then
		# Exactly one pwd match — use it automatically.
		if [[ ${#pwd_matches[@]} -eq 1 ]]; then
			echo "${pwd_matches[0]}"
			return
		fi

		# No live sessions responded — treat as no sessions.
		if [[ ${#entries[@]} -eq 0 ]]; then
			return
		fi
	fi

	# Show fzf picker with an extra "start new session" option.
	{
		[[ ${entries+1} ]] && printf '%s\n' "${entries[@]}"
		printf 'Start a new session in %s\t' "$PWD"
	} | fzf --with-nth=1 --accept-nth=2 --delimiter=$'\t' \
			--header='Pick an nvim session' \
			--height=~40% --reverse
}

launch_local() {
	# Running locally, run with a trampoline to support direnv
	script=$(printf 'cd %q && exec direnv exec . nvim "$@"' "$PWD")
	exec neovide-remote --no-tabs \
		--neovim-bin=sh \
		${argc_files+$(printf -- '--file=%q ' "${argc_files[@]}")} \
		-- -c "$script" neovide-tramoline --listen neovide
}

launch_remote() {
	# Running in a remote environment, open using iTerm2 custom escape sequence.
	echo "Launching Neovide through iTerm custom escape" >&2
	if [[ "${argc_files:+1}" ]]; then
		if [[ ${#argc_files[@]} -gt 1 ]]; then
			echo "Warning: only first file will be opened in remote mode" >&2
		fi
		local file="${argc_files[0]}"
		[[ "$file" != /* ]] && file="$PWD/$file"
		value="id=neovide:filename=$file"
	else
		value="id=neovide:"
	fi

	printf "\033]1337;RemoteHost=%s@%s\a\033]1337;CurrentDir=%s\a" "$USER" "$(hostname -f)" "$PWD"
	printf "\033]1337;Custom=%s\a" "$value"
	exit 0
}

if ! command -v argc >/dev/null; then
	echo "This command requires argc. Install from https://github.com/sigoden/argc" >&2
	exit 100
fi
eval "$(argc --argc-eval "$0" "$@")"

