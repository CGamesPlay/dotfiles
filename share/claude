#!/usr/bin/env bash
# @describe Wrapper for Claude Code.
#
# The wrapper can auto-install claude when needed.
# @version wrapper, use --claude-version for version information
# @flag -c --continue       Continue the last conversation
# @flag --yolo              "Dangerously" skip "permisisons".
# @flag --safehouse			Run in agent-safehouse on macOS (implies --yolo)
# @flag --claude-help       Show help for Claude Code
# @flag --claude-version    Show version for Claude Code
# @flag --claude-reinstall  Reinstall Claude Code even if already installed
# @flag --claude-login      Force OAuth token setup flow
# @arg args~                Additional arguments, passed verbatim

set -eu

# Things to potentially look into in the future:
# - web: https://github.com/All-Hands-AI/OpenHands
# - web: https://github.com/boldsoftware/sketch
# - nvim: https://github.com/olimorris/codecompanion.nvim
# - nvim: https://github.com/coder/claudecode.nvim

DFM_DIR=$(realpath -m "${BASH_SOURCE[0]}"/../..)

main() {
	if [[ "${argc_claude_reinstall+1}" ]] || ! compgen -G ~/.local/share/claude/versions/* > /dev/null; then
		echo "Claude Code is not installed. Installing..." >&2
		@get claude --force
	fi

	claude_bin=$(compgen -G ~/.local/share/claude/versions/* | sort -rV | head -n 1)

	if [[ ${argc_claude_help+1} ]] || [[ ${args_claude_version+1} ]]; then
		exec "$claude_bin" \
			${argc_claude_help+--help} \
			${argc_claude_version+--version}
	fi
	
	# Workaround for https://github.com/anthropics/claude-code/issues/14485
	local marketplace_file=~/.claude/plugins/known_marketplaces.json
	if [[ ! -f "$marketplace_file" ]]; then
		mkdir -p ~/.claude/plugins/marketplaces
		local now
		now=$(date -u +"%Y-%m-%dT%H:%M:%S.000Z")
		cat > "$marketplace_file" <<EOF
{
  "claude-plugins-official": {
    "source": {
      "source": "git",
      "url": "https://github.com/anthropics/claude-plugins-official.git"
    },
    "installLocation": "$HOME/.config/claude/plugins/marketplaces/claude-plugins-official",
    "lastUpdated": "$now"
  }
}
EOF
		git clone "https://github.com/anthropics/claude-plugins-official.git" ~/.claude/plugins/marketplaces/claude-plugins-official
	else
		jq 'walk(if type == "object" and has("repo") then .source = "git" | .url = ("https://github.com/" + .repo + ".git") | del(.repo) else . end)' \
			"$marketplace_file" > "$marketplace_file.tmp" && mv "$marketplace_file.tmp" "$marketplace_file"
	fi

	# It seems that each Claude account can only have a single refresh token.
	# This means that the short-lived tokens expire and the refresh token is
	# invalid whenever I log in to another devcontainer. We circumvent this
	# using the long-lived tokens designed for CI actions usage.
	local token_file=~/.claude/long-lived-token
	if [[ ! ${CLAUDE_CODE_OAUTH_TOKEN+1} ]] && [[ -f "$token_file" ]]; then
		CLAUDE_CODE_OAUTH_TOKEN="$(cat "$token_file")"
		export CLAUDE_CODE_OAUTH_TOKEN
	fi
	if [[ ${argc_claude_login+1} ]] || [[ ! ${CLAUDE_CODE_OAUTH_TOKEN+1} ]]; then
		echo "Setting up authentication..."
		"$claude_bin" setup-token

		# Update claude config with preferred settings
		local config_file=~/.claude.json
		node -e "
			const fs = require('fs');
			const config = JSON.parse(fs.readFileSync('$config_file', 'utf8'));
			config.theme = 'light';
			config.preferredNotifChannel = 'iterm2';
			config.hasCompletedOnboarding = true;
			fs.writeFileSync('$config_file', JSON.stringify(config, null, 2) + '\n');
		"

		echo "Write the long-lived OAuth token: pbpaste > $token_file" >&2
		echo 'Then run claude again.' >&2
		exit 100
	fi

	local args
	args=(
		"$claude_bin"
		${argc_continue:+--continue}
		${argc_resume:+--resume "$argc_resume"}
	)

	if [[ ${argc_safehouse+1} ]]; then
		if [[ "$(uname -s)" != "Darwin" ]]; then
			echo "--safehouse only works on macOS" >&2
			exit 100
		fi
		if ! command -v safehouse >/dev/null; then
			echo "Agent Safehouse is not installed. Installing..." >&2
			@get safehouse
		fi
		argc_yolo=1
		args=(
			safehouse 
			--add-dirs-ro ~/.local/bin
			--add-dirs-ro ~/.local/bin-after
			--add-dirs-ro "$NVM_DIR"
			--add-dirs-ro "$DFM_DIR"
			--add-dirs ~/.local/share/claude
			--add-dirs ~/.claude
			--add-dirs ~/.claude.json
			--env-pass "NVM_DIR,DFM_DIR,CLAUDE_CODE_OAUTH_TOKEN"
			-- "${args[@]}"
		)
	fi

	if [[ ${ATRIUM_WORKSPACE+1} ]] || [[ ${CODER+1} ]]; then
		args+=(--allow-dangerously-skip-permissions)
	fi
	if [[ ${argc_yolo+1} ]]; then
		args+=(--dangerously-skip-permissions)
	fi

	exec "${args[@]}" ${argc_args+-- "${argc_args[@]}"}
}

eval "$(argc --argc-eval "$0" "$@")"
