{
  "servers": [
    {
      "id": "dart",
      "extensions": [".dart"],
      "languageIds": { ".dart": "dart" },
      "spawnStrategy": "dart",
      "rootMarkers": ["pubspec.yaml", "analysis_options.yaml"],
      "warmupMarkers": ["pubspec.yaml"],
      "installHint": "Install the Dart SDK: https://dart.dev/get-dart"
    },
    {
      "id": "typescript",
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs", ".mts", ".cts"],
      "languageIds": {
        ".ts": "typescript",
        ".tsx": "typescriptreact",
        ".js": "javascript",
        ".jsx": "javascriptreact",
        ".mjs": "javascript",
        ".cjs": "javascript",
        ".mts": "typescript",
        ".cts": "typescript"
      },
      "spawnStrategy": "typescript",
      "rootMarkers": ["package.json", "tsconfig.json", "jsconfig.json"],
      "warmupMarkers": ["package.json"],
      "installHint": "npm i -g typescript-language-server typescript"
    },
    {
      "id": "vue",
      "extensions": [".vue"],
      "languageIds": { ".vue": "vue" },
      "command": "vue-language-server",
      "args": ["--stdio"],
      "rootMarkers": ["package.json", "vite.config.ts", "vite.config.js"],
      "installHint": "npm i -g @vue/language-server"
    },
    {
      "id": "svelte",
      "extensions": [".svelte"],
      "languageIds": { ".svelte": "svelte" },
      "command": "svelteserver",
      "args": ["--stdio"],
      "rootMarkers": ["package.json", "svelte.config.js"],
      "installHint": "npm i -g svelte-language-server"
    },
    {
      "id": "astro",
      "extensions": [".astro"],
      "languageIds": { ".astro": "astro" },
      "command": "astro-ls",
      "args": ["--stdio"],
      "rootMarkers": ["package.json", "astro.config.mjs", "astro.config.ts"],
      "installHint": "npm i -g @astrojs/language-server"
    },
    {
      "id": "pyright",
      "extensions": [".py", ".pyi"],
      "languageIds": { ".py": "python", ".pyi": "python" },
      "command": "pyright-langserver",
      "args": ["--stdio"],
      "rootMarkers": ["pyproject.toml", "setup.py", "requirements.txt", "pyrightconfig.json"],
      "warmupMarkers": ["pyproject.toml"],
      "installHint": "npm i -g pyright"
    },
    {
      "id": "gopls",
      "extensions": [".go"],
      "languageIds": { ".go": "go" },
      "command": "gopls",
      "args": [],
      "rootMarkersPreferred": ["go.work"],
      "rootMarkers": ["go.mod"],
      "warmupMarkers": ["go.mod"],
      "installHint": "go install golang.org/x/tools/gopls@latest"
    },
    {
      "id": "kotlin",
      "extensions": [".kt", ".kts"],
      "languageIds": { ".kt": "kotlin", ".kts": "kotlin" },
      "spawnStrategy": "kotlin",
      "rootMarkersPreferred": ["settings.gradle.kts", "settings.gradle"],
      "rootMarkers": ["build.gradle.kts", "build.gradle", "gradlew", "gradlew.bat", "gradle.properties", "pom.xml"],
      "warmupMarkers": ["settings.gradle", "settings.gradle.kts", "build.gradle", "build.gradle.kts", "pom.xml", "gradlew", "gradle.properties"],
      "diagnosticsTimeoutMs": 30000,
      "installHint": "Install Kotlin/kotlin-lsp (recommended) or org.javacs/kotlin-language-server"
    },
    {
      "id": "swift",
      "extensions": [".swift"],
      "languageIds": { ".swift": "swift" },
      "spawnStrategy": "swift",
      "rootStrategy": "swift",
      "rootMarkers": ["Package.swift"],
      "warmupMarkers": ["Package.swift"],
      "diagnosticsTimeoutMs": 20000,
      "installHint": "Install Xcode or Command Line Tools (sourcekit-lsp is bundled)"
    },
    {
      "id": "rust-analyzer",
      "extensions": [".rs"],
      "languageIds": { ".rs": "rust" },
      "command": "rust-analyzer",
      "args": [],
      "rootMarkers": ["Cargo.toml"],
      "warmupMarkers": ["Cargo.toml"],
      "diagnosticsTimeoutMs": 20000,
      "installHint": "rustup component add rust-analyzer"
    },
    {
      "id": "lua",
      "extensions": [".lua"],
      "languageIds": { ".lua": "lua" },
      "command": "lua-language-server",
      "args": ["--stdio"],
      "rootMarkers": [".luarc.json", ".luarc.jsonc", "stylua.toml", ".stylua.toml", "selene.toml"],
      "rootFallback": "cwd",
      "warmupMarkers": [".luarc.json"],
      "installHint": "brew install lua-language-server  # or :MasonInstall lua-language-server"
    }
  ]
}
