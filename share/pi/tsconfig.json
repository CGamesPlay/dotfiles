{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2023"]
  },
  "include": [
    "extensions/**/*.ts",
    "tests/**/*.ts",
    "extensions/customizations/**/*.ts",
    "test-harness/**/*.ts"
  ]
}
