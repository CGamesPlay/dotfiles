{
	"name": "@cgamesplay/pi-extensions",
	"type": "module",
	"scripts": {
		"check": "tsc --noEmit",
		"test": "tsx --test extensions/customizations/tests/**/*.test.ts",
		"test:update": "tsx --test --test-update-snapshots extensions/customizations/tests/**/*.test.ts"
	},
	"devDependencies": {
		"@types/node": "^24.0.0",
		"tsx": "^4.19.2",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@mariozechner/pi-coding-agent": "https://github.com/CGamesPlay/pi-mono/releases/download/latest/mariozechner-pi-coding-agent.tgz",
		"@mariozechner/pi-ai": "https://github.com/CGamesPlay/pi-mono/releases/download/latest/mariozechner-pi-ai.tgz",
		"@mariozechner/pi-tui": "https://github.com/CGamesPlay/pi-mono/releases/download/latest/mariozechner-pi-tui.tgz",
		"@sinclair/typebox": "^0.34.33",
		"diff": "^8.0.2",
		"vscode-languageserver-protocol": "^3.17.5"
	},
	"overrides": {
		"@mariozechner/pi-coding-agent": "$@mariozechner/pi-coding-agent",
		"@mariozechner/pi-ai": "$@mariozechner/pi-ai",
		"@mariozechner/pi-tui": "$@mariozechner/pi-tui",
		"@mariozechner/pi-agent-core": "https://github.com/CGamesPlay/pi-mono/releases/download/latest/mariozechner-pi-agent-core.tgz",
		"@mariozechner/pi-mom": "https://github.com/CGamesPlay/pi-mono/releases/download/latest/mariozechner-pi-mom.tgz",
		"@mariozechner/pi-web-ui": "https://github.com/CGamesPlay/pi-mono/releases/download/latest/mariozechner-pi-web-ui.tgz",
		"@mariozechner/pi": "https://github.com/CGamesPlay/pi-mono/releases/download/latest/mariozechner-pi.tgz"
	},
	"pi": {
		"extensions": [
			"./extensions"
		],
		"prompts": [
			"./prompts"
		]
	}
}
