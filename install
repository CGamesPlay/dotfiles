#!/usr/bin/make -f

SOURCE = $(CURDIR)/files
TARGET = $(HOME)

# Files to link directly
LINK_FILES := $(notdir $(shell find $(SOURCE) -maxdepth 1 -type f)) config/omf
# Link contents of these directories
LINK_CONTENTS_OF = vim/bundle ssh atom

# Assemble source and destination file lists
LINK_FILES_dest := $(addprefix $(TARGET)/.,$(LINK_FILES))
LINK_CONTENTS_OF_src := $(wildcard $(addsuffix /*,$(addprefix $(SOURCE)/,$(LINK_CONTENTS_OF))))
LINK_CONTENTS_OF_dest := $(LINK_CONTENTS_OF_src:$(SOURCE)/%=$(TARGET)/.%)

.PHONY: install uninstall omf_install

install: $(LINK_FILES_dest) $(LINK_CONTENTS_OF_dest) omf_install
	mkdir -p ~/.vim/swaps/
	vim -c VundleInstall -c qa
	apm install --packages-file ~/.atom/installed-packages.txt

uninstall:
	rm -i $(LINK_FILES_dest) $(LINK_CONTENTS_OF_dest)

omf_install: ~/.config/fish/config.fish
~/.config/fish/config.fish:
	# CI=1 prevents it from spawning a shell when complete
	curl -L https://github.com/oh-my-fish/oh-my-fish/raw/master/bin/install | CI=1 fish

# Main rule
$(TARGET)/.%: $(SOURCE)/%
	mkdir -p $(dir $@)
	ln -s $^ $@
